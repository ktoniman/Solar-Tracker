		(uuid "66652b0b-2263-469d-8f8e-4d5dbc874efc")
	)
	(text "datasheet says X5R or X7R caps \n"
		(exclude_from_sim no)
		(at 109.474 59.182 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "73fcfccf-78ad-48d1-8abb-98cf036f7891")
	)
	(text "Saturation current mus be higher than peak current, say servo draws 700 mA each\nthen theres ripple by the boost (check EPP1 for calculation of that). then add a margin"
		(exclude_from_sim no)
		(at 134.112 69.596 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "78287dfa-61a1-4bac-aed5-4609c2989146")
	)
	(text "Analog pins read (5V x  R)/R + LDR"
		(exclude_from_sim no)
		(at 107.696 107.188 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "7e945b65-4b17-4e15-9717-6312df4a5977")
	)
	(text "saturation current\n"
		(exclude_from_sim no)
		(at 106.426 23.114 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "9372ae9e-20d6-4fb6-b2a6-6a30c8bf5319")
	)
	(text "|(1/jwC)/((1/jwC) + R)| = 1/sqrt(1 + w^2C^2R^2)\n10^(-3/20)= 1/sqrt(1 + w^2C^2R^2)\nsqrt(1 + w^2C^2R^2) = 10^(3/20)\n1 + w^2C^2R^2 = 10^(3/10) \nw^2 = (10^(3/10)-1)/C^2R^2\nw = 997.6 rad/s\nf cutoff = 160 Hz.\ngood enough because human hand (and sun)\n will not change that quick"
		(exclude_from_sim no)
		(at 137.16 86.614 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "9d2817bc-fe16-4405-b3fb-e6ecfadaa757")
	)
	(text "Engineering Rule of Thumb\n\nFor every power IC:\n\n1 × 100nF per supply pin\n+ 1 bulk capacitor per rail\n\nPlace 100nF:\n\nAs close as physically possible\n\nShort traces\n\nDirect to ground plane"
		(exclude_from_sim no)
		(at 99.568 166.37 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "a1d6690f-3ec6-4ab1-b61a-92753e67a848")
	)
	(text "consider where to install heatsink"
		(exclude_from_sim no)
		(at 205.486 137.16 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "a50948d0-2377-41e8-ab29-ebfae10e3147")
	)
